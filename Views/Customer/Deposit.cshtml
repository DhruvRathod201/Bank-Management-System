@model BankManagementSystem.DTOs.DepositDto
@using BankManagementSystem.Models
@{
    Layout = "_CustomerLayout";
    ViewData["Title"] = "Instant Credit";
    ViewData["Active"] = "Deposit";
    var accounts = ViewBag.Accounts as List<Account> ?? new();
    var selectedId = ViewBag.SelectedAccountId as int?;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header py-3">
                <h6 class="mb-0"><i class="bi bi-lightning me-2"></i>Instant Credit</h6>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info small mb-4">
                    <i class="bi bi-info-circle me-1"></i>
                    <strong>How it works:</strong> The bank temporarily credits your account. You must repay the amount physically at our branch within <strong>3 days</strong>. Maximum: <strong>₹10,000</strong>. Whole numbers only. <strong>Frozen accounts cannot use this.</strong>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger py-2 mb-3"><i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]</div>
                }

                <form asp-action="Deposit" method="post">
                    <div class="mb-3">
                        <label class="form-label">Select Account</label>
                        <select asp-for="AccountId" class="form-select">
                            <option value="">Choose account...</option>
                            @foreach (var acc in accounts)
                            {
                                var pendingCredit = acc.InstantCredits.Any(c => c.Status == CreditStatus.PendingSettlement);
                                var isFrozen = acc.Status == AccountStatus.Frozen;
                                var isClosed = acc.Status == AccountStatus.Closed;
                                var disabled = pendingCredit || isFrozen || isClosed;
                                var suffix = pendingCredit ? " [Credit Pending]"
                                           : isFrozen ? " [Frozen]"
                                           : isClosed ? " [Closed]" : "";
                                var label = $"{acc.AccountNumber} – ₹{acc.Balance:N0} ({acc.AccountType}){suffix}";

                                if (disabled)
                                {
                                    <option value="@acc.Id" disabled>@label</option>
                                }
                                else if (selectedId == acc.Id)
                                {
                                    <option value="@acc.Id" selected>@label</option>
                                }
                                else
                                {
                                    <option value="@acc.Id">@label</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="AccountId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Amount (₹)</label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input asp-for="Amount" class="form-control" type="number" min="1" max="10000" step="1"
                                   placeholder="Enter whole amount (max ₹10,000)"
                                   oninput="this.value=Math.floor(Math.abs(this.value)||'')" />
                        </div>
                        <div class="d-flex gap-2 mt-2 flex-wrap">
                            @foreach (var amt in new[]{1000, 2000, 5000, 10000})
                            {
                                <button type="button" class="btn btn-sm btn-outline-secondary"
                                        onclick="document.querySelector('[name=Amount]').value=@amt">₹@amt.ToString("N0")</button>
                            }
                        </div>
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-lightning me-2"></i>Request Instant Credit
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
