@using BankManagementSystem.Models
@{
    Layout = "_CustomerLayout";
    var acc = ViewBag.Account as Account;
    var txns = ViewBag.Transactions as List<Transaction> ?? new();
    ViewData["Title"] = $"Account – {acc?.AccountNumber}";
    ViewData["Active"] = "Accounts";
    var pendingCredits = acc?.InstantCredits.Where(c => c.Status == CreditStatus.PendingSettlement).ToList() ?? new();
    var sc = acc?.Status == AccountStatus.Active ? "success" : acc?.Status == AccountStatus.Frozen ? "warning" : "secondary";
    var gradient = acc?.AccountType == AccountType.Savings ? "linear-gradient(135deg,#1a2a6c,#2196F3)"
                 : acc?.AccountType == AccountType.Current ? "linear-gradient(135deg,#11998e,#38ef7d)"
                 : "linear-gradient(135deg,#f7971e,#ffd200)";
}

<div class="mb-3">
    <a asp-action="Accounts" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Accounts</a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm overflow-hidden mb-3">
            <div class="p-4 text-white" style="background:@gradient">
                <div class="d-flex justify-content-between mb-3">
                    <div>
                        <div class="small opacity-75">@acc?.AccountType Account</div>
                        <div class="fw-bold fs-5">@acc?.AccountNumber</div>
                    </div>
                    <span class="badge bg-white text-dark">@acc?.Status</span>
                </div>
                <div class="small opacity-75">Available Balance</div>
                <div class="fw-bold fs-2">₹@acc?.Balance.ToString("N2")</div>
            </div>
            <div class="card-body">
                <div class="mb-2 d-flex justify-content-between">
                    <span class="text-muted small">Account Type</span>
                    <span class="fw-semibold small">@acc?.AccountType</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                    <span class="text-muted small">Status</span>
                    <span class="badge bg-@sc-subtle text-@sc">@acc?.Status</span>
                </div>
                <div class="mb-2 d-flex justify-content-between">
                    <span class="text-muted small">Opened</span>
                    <span class="fw-semibold small">@acc?.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
                @if (pendingCredits.Any())
                {
                    <div class="alert alert-warning small mt-2 py-2">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Outstanding Credit: <strong>₹@pendingCredits.Sum(c => c.Amount).ToString("N0")</strong>
                        <br />
                        <small>Due: @pendingCredits.Min(c => c.Deadline).ToString("dd MMM yyyy")</small>
                    </div>
                }
            </div>
        </div>

        @if (acc?.Status == AccountStatus.Active)
        {
            <div class="d-grid gap-2">
                <a asp-action="Deposit" asp-route-accountId="@acc.Id" class="btn btn-success"><i class="bi bi-arrow-down-circle me-1"></i>Deposit</a>
                <a asp-action="Withdraw" asp-route-accountId="@acc.Id" class="btn btn-warning"><i class="bi bi-arrow-up-circle me-1"></i>Withdraw</a>
                <a asp-action="Transfer" asp-route-accountId="@acc.Id" class="btn btn-info text-white"><i class="bi bi-arrow-left-right me-1"></i>Transfer</a>
            </div>
        }
        else if (acc?.Status == AccountStatus.Frozen)
        {
            <div class="alert alert-warning">
                <i class="bi bi-lock me-1"></i><strong>Account Frozen</strong>
                <p class="small mb-0 mt-1">You can deposit but cannot withdraw or transfer.</p>
            </div>
            <a asp-action="Deposit" asp-route-accountId="@acc.Id" class="btn btn-success w-100"><i class="bi bi-arrow-down-circle me-1"></i>Deposit</a>
        }
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center py-3">
                <h6 class="mb-0 fw-bold">Recent Transactions</h6>
                <a asp-controller="Customer" asp-action="Transactions" class="btn btn-sm btn-outline-primary">Full History</a>
            </div>
            <div class="card-body p-0">
                @if (!txns.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-clock-history fs-1"></i>
                        <p class="mt-2">No transactions yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr><th>Date</th><th>Type</th><th>Amount</th><th>Description</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var txn in txns)
                                {
                                    var isIn = txn.Type == TransactionType.InstantCredit || (txn.Type == TransactionType.Transfer && txn.Description.StartsWith("Transfer from"));
                                    var tc = txn.Type switch {
                                        TransactionType.InstantCredit => "primary",
                                        TransactionType.CreditSettlement => "info",
                                        TransactionType.Withdraw => "danger",
                                        TransactionType.Transfer => "warning",
                                        _ => "secondary"
                                    };
                                    <tr>
                                        <td class="text-muted small">@txn.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                        <td><span class="badge bg-@tc-subtle text-@tc">@txn.Type</span></td>
                                        <td class="fw-semibold @(isIn ? "text-success" : "text-danger")">@(isIn ? "+" : "-") ₹@txn.Amount.ToString("N2")</td>
                                        <td class="text-muted small">@txn.Description</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
