@{
    Layout = "_Layout";
    ViewData["Title"] = "Welcome";
}

<div class="auth-bg-dark">
    <div class="auth-content d-flex align-items-center justify-content-center min-vh-100 px-3">
        <div class="auth-card p-5" style="max-width:500px;width:100%">

            <!-- Top gold bar -->
            <div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--burgundy),var(--gold),var(--burgundy))"></div>

            <!-- Logo seal -->
            <div class="text-center mb-4">
                <div class="auth-logo-seal mb-3">
                    <i class="bi bi-bank2"></i>
                </div>
                <div class="auth-title">NEXBank</div>
                <div class="auth-subtitle">Your trusted banking partner</div>
            </div>

            <div class="ornament mb-4">Est. Since Excellence</div>

            <!-- Features -->
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="feature-tile">
                        <div class="feature-icon-box fi-burg"><i class="bi bi-shield-check"></i></div>
                        <small>Secure Banking</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="feature-tile">
                        <div class="feature-icon-box fi-green"><i class="bi bi-arrow-left-right"></i></div>
                        <small>Easy Transfers</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="feature-tile">
                        <div class="feature-icon-box fi-gold"><i class="bi bi-cash-coin"></i></div>
                        <small>Instant Credit</small>
                    </div>
                </div>
                <div class="col-6">
                    <div class="feature-tile">
                        <div class="feature-icon-box fi-blue"><i class="bi bi-graph-up"></i></div>
                        <small>Track Spending</small>
                    </div>
                </div>
            </div>

            <!-- CTAs -->
            <div class="d-grid gap-2">
                <a asp-controller="Auth" asp-action="Login" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login to Your Account
                </a>
                <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-person-plus me-2"></i>Open New Account
                </a>
            </div>

            <div style="height:1px;background:linear-gradient(90deg,transparent,rgba(201,168,76,.3),transparent);margin-top:1.5rem"></div>
        </div>
    </div>
</div>
