@model BankManagementSystem.DTOs.LoginDto
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="auth-bg-dark">
    <div class="auth-content d-flex align-items-center justify-content-center min-vh-100 px-3">
        <div class="auth-card p-5" style="max-width:430px;width:100%">

            <div class="text-center mb-4">
                <div class="auth-logo-seal mb-3">
                    <i class="bi bi-bank2"></i>
                </div>
                <div class="auth-title">Welcome Back</div>
                <div class="auth-subtitle">Sign in to NEXBank</div>
            </div>

            <div class="ornament mb-4">Secure Access</div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger py-2 mb-3"><i class="bi bi-exclamation-circle me-1"></i> @TempData["Error"]</div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success py-2 mb-3"><i class="bi bi-check-circle me-1"></i> @TempData["Success"]</div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="your@email.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" id="loginPwd" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePwd('loginPwd',this)"><i class="bi bi-eye"></i></button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login
                    </button>
                </div>
            </form>

            <div style="height:1px;background:linear-gradient(90deg,transparent,rgba(201,168,76,.25),transparent);margin:1.25rem 0"></div>
            <p class="text-center mb-0" style="font-family:'EB Garamond',serif;font-size:1rem;color:var(--muted)">
                Don't have an account? <a asp-controller="Auth" asp-action="Register" style="color:var(--burgundy);font-weight:700">Register here</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePwd(id, btn) {
    const el = document.getElementById(id);
    const isText = el.type === 'text';
    el.type = isText ? 'password' : 'text';
    btn.innerHTML = isText ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
}
</script>
}
