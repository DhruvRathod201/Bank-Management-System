@using BankManagementSystem.Models
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Reports";
    ViewData["Active"] = "Reports";
    var txns = ViewBag.Transactions as List<Transaction> ?? new();
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">From Date</label>
                <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.From" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small mb-1">To Date</label>
                <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.To" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Generate Report</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card stat-blue">
            <div class="stat-icon"><i class="bi bi-arrow-down-circle"></i></div>
            <div class="stat-value">₹@((ViewBag.TotalDeposits as decimal? ?? 0).ToString("N0"))</div>
            <div class="stat-label">Total Deposits (IC)</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-orange">
            <div class="stat-icon"><i class="bi bi-arrow-up-circle"></i></div>
            <div class="stat-value">₹@((ViewBag.TotalWithdrawals as decimal? ?? 0).ToString("N0"))</div>
            <div class="stat-label">Total Withdrawals</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-green">
            <div class="stat-icon"><i class="bi bi-arrow-left-right"></i></div>
            <div class="stat-value">₹@((ViewBag.TotalTransfers as decimal? ?? 0).ToString("N0"))</div>
            <div class="stat-label">Total Transfers</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-red">
            <div class="stat-icon"><i class="bi bi-list-ul"></i></div>
            <div class="stat-value">@(ViewBag.TransactionCount ?? 0)</div>
            <div class="stat-label">Total Transactions</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="mb-0 fw-bold">Transaction Details — @ViewBag.From to @ViewBag.To</h6>
    </div>
    <div class="card-body p-0">
        @if (!txns.Any())
        {
            <div class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1"></i><p class="mt-2">No transactions in this period.</p></div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>#</th><th>Customer</th><th>Account</th><th>Type</th><th>Amount</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var t in txns)
                        {
                            var tc = t.Type switch {
                                TransactionType.InstantCredit => "primary",
                                TransactionType.CreditSettlement => "info",
                                TransactionType.Withdraw => "danger",
                                TransactionType.Transfer => "warning",
                                _ => "secondary"
                            };
                            <tr>
                                <td class="text-muted small">@t.Id</td>
                                <td class="small fw-semibold">@t.Account.Customer.User.FullName</td>
                                <td class="small">@t.Account.AccountNumber</td>
                                <td><span class="badge bg-@tc-subtle text-@tc">@t.Type</span></td>
                                <td class="fw-bold">₹@t.Amount.ToString("N2")</td>
                                <td class="text-muted small">@t.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
