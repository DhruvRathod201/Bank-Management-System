@using BankManagementSystem.Models
@model AccountRequest
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Account Request Details";
    ViewData["Active"] = "PendingRequests";
}

<div class="mb-3">
    <a asp-action="PendingRequests" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm p-4">
            <h6 class="fw-bold mb-3 text-muted">APPLICANT</h6>
            <div class="mb-2"><small class="text-muted">Name</small><div class="fw-semibold">@Model.Customer.User.FullName</div></div>
            <div class="mb-2"><small class="text-muted">Email</small><div class="fw-semibold">@Model.Customer.User.Email</div></div>
            <div class="mb-2"><small class="text-muted">Phone</small><div class="fw-semibold">@Model.Customer.Phone</div></div>
            <div class="mb-2"><small class="text-muted">Account Type Requested</small>
                <div><span class="badge bg-primary fs-6">@Model.AccountType</span></div>
            </div>
            <div class="mb-2"><small class="text-muted">Requested On</small><div class="fw-semibold">@Model.RequestedAt.ToString("dd MMM yyyy HH:mm")</div></div>
            <div><small class="text-muted">Status</small>
                <div><span class="badge bg-warning-subtle text-warning fs-6">@Model.Status</span></div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-bottom py-3">
                <h6 class="mb-0 fw-bold">Application Details – @Model.AccountType Account</h6>
            </div>
            <div class="card-body">
                @if (Model.AccountType == AccountType.Savings)
                {
                    <div class="row g-3">
                        <div class="col-md-6"><small class="text-muted">Address</small><div class="fw-semibold">@(Model.Address ?? "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Occupation</small><div class="fw-semibold">@(Model.Occupation ?? "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Monthly Salary</small><div class="fw-semibold">@(Model.MonthlySalary.HasValue ? "₹" + Model.MonthlySalary.Value.ToString("N0") : "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Family Members</small><div class="fw-semibold">@(Model.FamilyMembers ?? 0)</div></div>
                        <div class="col-md-6"><small class="text-muted">Nominee Name</small><div class="fw-semibold">@(Model.NomineeName ?? "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Nominee Relation</small><div class="fw-semibold">@(Model.NomineeRelation ?? "—")</div></div>
                    </div>
                }
                else if (Model.AccountType == AccountType.Current)
                {
                    <div class="row g-3">
                        <div class="col-md-6"><small class="text-muted">Business Name</small><div class="fw-semibold">@(Model.BusinessName ?? "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Business Type</small><div class="fw-semibold">@(Model.BusinessType ?? "—")</div></div>
                        <div class="col-md-12"><small class="text-muted">Business Address</small><div class="fw-semibold">@(Model.BusinessAddress ?? "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Annual Income</small><div class="fw-semibold">@(Model.AnnualIncome.HasValue ? "₹" + Model.AnnualIncome.Value.ToString("N0") : "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Employees Count</small><div class="fw-semibold">@(Model.EmployeesCount ?? 0)</div></div>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        <div class="col-md-6"><small class="text-muted">Deposit Amount</small><div class="fw-semibold">@(Model.DepositAmount.HasValue ? "₹" + Model.DepositAmount.Value.ToString("N0") : "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Duration</small><div class="fw-semibold">@(Model.DurationMonths.HasValue ? Model.DurationMonths + " months" : "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Nominee Name</small><div class="fw-semibold">@(Model.NomineeName ?? "—")</div></div>
                        <div class="col-md-6"><small class="text-muted">Nominee Relation</small><div class="fw-semibold">@(Model.NomineeRelation ?? "—")</div></div>
                    </div>
                }
            </div>
            @if (Model.Status == RequestStatus.Pending)
            {
                <div class="card-footer bg-white border-top d-flex gap-2 py-3">
                    <form asp-action="ApproveRequest" asp-route-id="@Model.Id" method="post">
                        <button class="btn btn-success fw-semibold" onclick="return confirm('Approve and create account?')">
                            <i class="bi bi-check-circle me-1"></i> Approve & Create Account
                        </button>
                    </form>
                    <button class="btn btn-danger fw-semibold" data-bs-toggle="modal" data-bs-target="#rejectModal">
                        <i class="bi bi-x-circle me-1"></i> Reject
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Reject Request</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form asp-action="RejectRequest" asp-route-id="@Model.Id" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Reason for Rejection</label>
                        <textarea name="notes" class="form-control" rows="3" placeholder="Enter reason..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>
