@using BankManagementSystem.Models
@model List<InstantCredit>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Instant Credit Management";
    ViewData["Active"] = "InstantCredits";
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-bottom py-3">
        <h6 class="mb-0 fw-bold">Pending Instant Credits <span class="badge bg-warning ms-1">@Model.Count</span></h6>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-check-circle fs-1 text-success"></i>
                <p class="mt-2">No pending instant credits.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>#</th><th>Customer</th><th>Account</th><th>Amount</th><th>Issued</th><th>Deadline</th><th>Status</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var ic in Model)
                        {
                            var daysLeft = (ic.Deadline - DateTime.UtcNow).Days;
                            var urgency = daysLeft <= 0 ? "danger" : daysLeft <= 1 ? "warning" : "success";
                            <tr class="@(daysLeft <= 0 ? "table-danger" : "")">
                                <td class="text-muted small">@ic.Id</td>
                                <td class="fw-semibold small">@ic.Account.Customer.User.FullName</td>
                                <td class="small">@ic.Account.AccountNumber</td>
                                <td class="fw-bold">₹@ic.Amount.ToString("N2")</td>
                                <td class="text-muted small">@ic.IssuedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge bg-@urgency-subtle text-@urgency">
                                        @ic.Deadline.ToString("dd MMM yyyy")
                                        @if (daysLeft <= 0)
                                        {
                                            <span>(OVERDUE)</span>
                                        }
                                        else
                                        {
                                            <span>(@daysLeft d left)</span>
                                        }
                                    </span>
                                </td>
                                <td><span class="badge bg-warning-subtle text-warning">@ic.Status</span></td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <form asp-action="SettleCredit" asp-route-id="@ic.Id" method="post" class="d-inline">
                                            <button class="btn btn-xs btn-success" onclick="return confirm('Mark as settled? This will deduct ₹@ic.Amount from the account.')" title="Mark Settled">
                                                <i class="bi bi-check-circle me-1"></i>Settle
                                            </button>
                                        </form>
                                        <button class="btn btn-xs btn-info" data-bs-toggle="modal" data-bs-target="#extendModal-@ic.Id" title="Extend Deadline">
                                            <i class="bi bi-calendar-plus me-1"></i>Extend
                                        </button>
                                        <form asp-action="FreezeAccountFromCredit" asp-route-accountId="@ic.AccountId" method="post" class="d-inline">
                                            <button class="btn btn-xs btn-warning" onclick="return confirm('Freeze this account?')" title="Freeze Account">
                                                <i class="bi bi-lock me-1"></i>Freeze
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>

                            <!-- Extend Modal -->
                            <div class="modal fade" id="extendModal-@ic.Id" tabindex="-1">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">Extend Deadline</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <form asp-action="ExtendDeadline" asp-route-id="@ic.Id" method="post">
                                            <div class="modal-body">
                                                <p>Extending deadline for <strong>@ic.Account.Customer.User.FullName</strong> – ₹@ic.Amount.ToString("N0")</p>
                                                <p>Current deadline: <strong>@ic.Deadline.ToString("dd MMM yyyy")</strong></p>
                                                <div class="mb-3">
                                                    <label class="form-label fw-semibold">Extend by (days)</label>
                                                    <select name="days" class="form-select">
                                                        <option value="1">1 Day</option>
                                                        <option value="3" selected>3 Days</option>
                                                        <option value="7">7 Days</option>
                                                        <option value="14">14 Days</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-info text-white">Extend Deadline</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
