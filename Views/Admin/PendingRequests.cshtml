@using BankManagementSystem.Models
@model List<AccountRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Account Requests";
    ViewData["Active"] = "PendingRequests";
    var pending = Model.Where(r => r.Status == RequestStatus.Pending).ToList();
    var approved = Model.Where(r => r.Status == RequestStatus.Approved).ToList();
    var rejected = Model.Where(r => r.Status == RequestStatus.Rejected).ToList();
}

<!-- Summary pills -->
<div class="d-flex gap-3 mb-4">
    <span class="badge px-3 py-2 fs-6" style="background:var(--gold-pale);color:var(--gold-dark);font-family:'Cinzel',serif">
        <i class="bi bi-hourglass-split me-1"></i>@pending.Count Pending
    </span>
    <span class="badge px-3 py-2 fs-6" style="background:#EDF7F2;color:#1A4A2A;font-family:'Cinzel',serif">
        <i class="bi bi-check-circle me-1"></i>@approved.Count Approved
    </span>
    <span class="badge px-3 py-2 fs-6" style="background:var(--burgundy-pale);color:var(--burgundy);font-family:'Cinzel',serif">
        <i class="bi bi-x-circle me-1"></i>@rejected.Count Rejected
    </span>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1"></i>
            <p class="mt-2">No account requests yet.</p>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-header py-3">
            <h6 class="mb-0">All Account Requests</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr><th>#</th><th>Customer</th><th>Type</th><th>Requested</th><th>Status</th><th>Reason</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.OrderByDescending(x => x.RequestedAt))
                        {
                            var rowClass = r.Status == RequestStatus.Pending ? "" :
                                          r.Status == RequestStatus.Approved ? "table-success" : "table-danger";
                            <tr class="@rowClass">
                                <td class="text-muted small">@r.Id</td>
                                <td>
                                    <div class="fw-semibold">@r.Customer.User.FullName</div>
                                    <div class="text-muted small">@r.Customer.User.Email</div>
                                </td>
                                <td><span class="badge bg-primary-subtle text-primary">@r.AccountType</span></td>
                                <td class="text-muted small">@r.RequestedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    @if (r.Status == RequestStatus.Pending)
                                    {
                                        <span class="badge bg-warning-subtle text-warning">Pending</span>
                                    }
                                    else if (r.Status == RequestStatus.Approved)
                                    {
                                        <span class="badge bg-success-subtle text-success">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">Rejected</span>
                                    }
                                </td>
                                <td class="text-muted small" style="max-width:180px">
                                    @if (r.Status == RequestStatus.Rejected && !string.IsNullOrEmpty(r.AdminNotes))
                                    {
                                        <span class="text-danger" title="@r.AdminNotes">
                                            <i class="bi bi-chat-left-text me-1"></i>@(r.AdminNotes.Length > 40 ? r.AdminNotes[..40] + "…" : r.AdminNotes)
                                        </span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>
                                    <div class="d-flex gap-1 flex-wrap">
                                        <a asp-action="RequestDetails" asp-route-id="@r.Id" class="btn btn-xs btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                        @if (r.Status == RequestStatus.Pending)
                                        {
                                            <form asp-action="ApproveRequest" asp-route-id="@r.Id" method="post" class="d-inline">
                                                <button class="btn btn-xs btn-success" onclick="return confirm('Approve this account request?')">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </form>
                                            <button class="btn btn-xs btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal-@r.Id">
                                                <i class="bi bi-x-lg"></i> Reject
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>

                            @if (r.Status == RequestStatus.Pending)
                            {
                                <!-- Reject Modal -->
                                <div class="modal fade" id="rejectModal-@r.Id" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Reject Account Request</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="RejectRequest" asp-route-id="@r.Id" method="post">
                                                <div class="modal-body">
                                                    <p>Rejecting request from <strong>@r.Customer.User.FullName</strong> for a <strong>@r.AccountType</strong> account.</p>
                                                    <div class="mb-3">
                                                        <label class="form-label">Reason for Rejection <span class="text-muted">(shown to customer)</span></label>
                                                        <textarea name="notes" class="form-control" rows="3" placeholder="e.g. Incomplete documentation, does not meet eligibility criteria..."></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
