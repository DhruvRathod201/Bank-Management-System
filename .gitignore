## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUNIT
CompileLog.txt

# Visual Studio Code
.vscode/

# Rider
.idea/

# Entity Framework Core
*.db
*.db-shm
*.db-wal

# Backup & temp files from WinMerge and other tools
*.bak
*.cache
*.out
*.err

# Service Fabric
*.manifest

# Others
appsettings.Development.json
node_modules/
.DS_Store
